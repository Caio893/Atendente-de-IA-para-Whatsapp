# WhatsApp chat id or phone digits. Prefer international format without "+".
# Example Brazil/Sao Paulo: 5511987654321
ADMIN_PHONE_NUMBER=5511999999999

# HTTP health endpoint. Keep PORT=3001 on the VPS to avoid other services.
HOST=0.0.0.0
PORT=3001

# OpenAI API configuration.
# Never commit a real API key. Put the real value only in .env on your machine or VPS.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI runtime options for the !ia / !llm admin command.
LLM_TIMEOUT_MS=30000
LLM_TEMPERATURE=0.2
# Enables OpenAI-generated customer replies plus structured scheduling extraction.
CUSTOMER_AI_ASSISTANT_ENABLED=true
# Optional override. Leave blank to use the built-in Portuguese admin prompt.
# AI_SYSTEM_PROMPT=

# Delay used to group quick customer messages before the bot replies.
CUSTOMER_REPLY_DELAY_MS=10000
CUSTOMER_FOLLOW_UP_REPLY_DELAY_MS=5000
# Keep customer chats visibly unread after automatic bot replies, so employees can review them.
MARK_BOT_REPLIES_UNREAD=true
# After !reset/!reativar/!designorar, one manual employee message can be sent
# without immediately pausing automation again.
HUMAN_TAKEOVER_SUPPRESSION_MS=300000
# Prevent endless automatic conversations when another bot talks to this bot.
BOT_LOOP_WINDOW_MS=600000
BOT_LOOP_MAX_AUTO_REPLIES=6

# Audio transcription for live WhatsApp audio messages.
# This only processes new incoming audio while the automatic bot flow is active.
# Put a Linux whisper.cpp binary at ./bin/whisper-cli and a tiny/base model at ./models.
AUDIO_TRANSCRIPTION_ENABLED=true
WHISPER_CPP_BIN=/app/bin/whisper-cli
WHISPER_MODEL_PATH=/app/models/ggml-tiny.bin
WHISPER_LANGUAGE=pt
FFMPEG_PATH=ffmpeg
AUDIO_TRANSCRIPTION_TIMEOUT_MS=120000
MAX_AUDIO_TRANSCRIPTION_BYTES=10485760
MAX_AUDIO_TRANSCRIPTION_CHARS=4000
WHISPER_THREADS=1
FFMPEG_THREADS=1
AUDIO_TRANSCRIPTION_MAX_CONCURRENCY=1
AUDIO_TRANSCRIPTION_MAX_QUEUE=3

# Conservative container limits for a small VPS running Chromium + Whisper tiny.
WHATSAPP_BOT_CPUS=1.0
WHATSAPP_BOT_MEM_LIMIT=1800m
WHATSAPP_BOT_MEMSWAP_LIMIT=2200m

# Factory presentation video sent on the first customer response.
# Put the video at ./media/forte-lajes-fabrica.mp4 on the host.
FACTORY_VIDEO_PATH=/app/media/forte-lajes-fabrica.mp4
FACTORY_VIDEO_CAPTION=Apresentamos a fabrica da Forte Lajes.\n\nTrabalhamos com trelicas ArcelorMittal ou Gerdau, duas das marcas mais reconhecidas do mercado.\n\nNossas vigas ja sao fabricadas e ficam disponiveis para entrega, com controle de qualidade em todas as etapas. Tambem utilizamos isopor de excelente qualidade, reduzindo riscos na substituicao dos antigos tijolos e contribuindo para uma obra mais leve, confortavel, elegante e ecologicamente correta.\n\nNosso traco de fabricacao utiliza concreto FCK 30.

# Persistence paths inside the container.
SQLITE_DB_PATH=/app/data/database.sqlite
AUTH_DATA_PATH=/app/.wwebjs_auth

# Cron schedules are interpreted in CRON_TIMEZONE.
CRON_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo
MORNING_REMINDER_CRON=0 7 * * *
NIGHT_REMINDER_CRON=0 22 * * *
MISSED_RUN_CHECK_CRON=*/5 * * * *
ENABLE_MISSED_RUN_RECOVERY=true

# Removes stale Chromium Singleton* files left after an unclean container stop.
# Keep true for a single bot container. Do not share the same auth volume across replicas.
CLEANUP_CHROMIUM_PROFILE_LOCKS=true

# Chromium path installed by the Dockerfile.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Docker resource limits used by docker-compose.yml.
WHATSAPP_BOT_MEM_LIMIT=1200m
WHATSAPP_BOT_MEMSWAP_LIMIT=1500m
WHATSAPP_BOT_CPUS=1.0
WHATSAPP_BOT_PIDS_LIMIT=200
WHATSAPP_BOT_SHM_SIZE=256m

# Runtime safety limits.
WHATSAPP_OPERATION_TIMEOUT_MS=45000
WHATSAPP_WATCHDOG_INTERVAL_MS=60000
WHATSAPP_WATCHDOG_TIMEOUT_MS=15000
WHATSAPP_WATCHDOG_MAX_FAILURES=3
MAX_PENDING_CUSTOMERS=100
MAX_QUEUED_MESSAGES_PER_CUSTOMER=10
MAX_QUEUED_MESSAGE_CHARS=4000
MAX_SESSION_CACHE_ENTRIES=1000
SESSION_CACHE_TTL_MS=86400000
MAX_FACTORY_VIDEO_BYTES=20971520

LOG_LEVEL=info
